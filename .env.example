# Moodle DR Dashboard — Environment Variables
# Copy to .env and fill in your values. Never commit .env to version control.

# ── Target (Azure / remote VM) ─────────────────────────────────────────────────
AZURE_VM_IP=                        # e.g. 10.0.0.5  or  your-vm.region.cloudapp.azure.com
AZURE_VM_USER=moodlesync            # SSH user on the target VM (do not change unless you renamed it)

# ── SSH / File Sync ────────────────────────────────────────────────────────────
SSH_KEY_PATH=/root/.ssh/moodle_rsync_ed25519
SOURCE_PATH=/var/www/Azure-MoodleData/
TARGET_PATH=/moodledata/

# ── Dashboard ──────────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info
STATE_FILE=/var/lib/moodle-dr/setup-state.json

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# ── Notifications (optional) ───────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# SLACK_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=
